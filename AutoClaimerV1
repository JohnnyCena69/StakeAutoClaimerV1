  function drawGraph() {
    const c = document.getElementById('scp-graph');
    if (!c || graphData.length < 2) return;
    const ctx = c.getContext('2d');
    ctx.clearRect(0, 0, c.width, c.height);
    const max = Math.max(...graphData), min = Math.min(...graphData);
    const range = max - min || 1;
    const pL = 36, pB = 14, pT = 6;
    const w = c.width - pL, h = c.height - pB - pT;

    ctx.strokeStyle = '#1a2c38'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(pL, pT); ctx.lineTo(pL, pT + h); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(pL, pT + h); ctx.lineTo(c.width, pT + h); ctx.stroke();
    ctx.fillStyle = '#3a5a6a'; ctx.font = '8px monospace'; ctx.textAlign = 'right';
    ctx.fillText('$' + max.toFixed(1), pL - 2, pT + 7);
    ctx.fillText('$' + min.toFixed(1), pL - 2, pT + h);

    const grad = ctx.createLinearGradient(0, pT, 0, pT + h);
    grad.addColorStop(0, 'rgba(0,255,136,0.2)');
    grad.addColorStop(1, 'rgba(0,255,136,0)');
    ctx.beginPath();
    graphData.forEach((v, i) => {
      const x = pL + i * (w / (graphData.length - 1));
      const y = pT + h - ((v - min) / range) * h;
      i ? ctx.lineTo(x, y) : ctx.moveTo(x, y);
    });
    ctx.lineTo(pL + w, pT + h); ctx.lineTo(pL, pT + h);
    ctx.closePath(); ctx.fillStyle = grad; ctx.fill();

    ctx.beginPath(); ctx.lineWidth = 1.5; ctx.strokeStyle = '#00ff88';
    graphData.forEach((v, i) => {
      const x = pL + i * (w / (graphData.length - 1));
      const y = pT + h - ((v - min) / range) * h;
      i ? ctx.lineTo(x, y) : ctx.moveTo(x, y);
    });
    ctx.stroke();
  }

